# --- SSH connection to the remote host --------------------------------------

SSH_HOST=example.com
SSH_PORT=22
SSH_USER=deploy

# Absolute path to a private key file (preferred over SSH_PASSWORD).
SSH_KEY_PATH=/path/to/.ssh/id_ed25519
# SSH_KEY_PASSPHRASE=

# Fallback to password auth. Not recommended; prefer SSH_KEY_PATH.
# SSH_PASSWORD=

# --- Docker on the remote (optional) ----------------------------------------
#
# Set DOCKER_ENABLED=false on a host with no Docker — the 8 Docker tools are
# then not registered, so the MCP client won't see or try them. Host- and
# nginx-level tools always work without Docker.

DOCKER_ENABLED=true
DOCKER_BIN=docker
# DEFAULT_COMPOSE_DIR=/srv/app
# DEFAULT_COMPOSE_PROJECT=app
# DEFAULT_CONTAINERS=app,worker,mongo

# --- MongoDB activity probe (optional) --------------------------------------

# check_db_activity runs mongosh inside this container, so MONGO_URI is
# resolved from inside the container (use mongodb://localhost:27017 when
# mongosh and mongod live in the same container).
# MONGO_CONTAINER=mongo
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB=app
# MONGO_COLLECTIONS=users,events,jobs

# --- Nginx (optional) -------------------------------------------------------
#
# Set NGINX_ENABLED=false on a host without nginx — the `nginx_config` tool
# is then not registered.

NGINX_ENABLED=true
# Set NGINX_BIN to 'sudo nginx' if the SSH user can't run `nginx -T` directly.
NGINX_BIN=nginx

# --- Caddy (optional) -------------------------------------------------------
#
# Set CADDY_ENABLED=false on a host without Caddy. The caddy_config tool
# fetches the running config from Caddy's admin API.

CADDY_ENABLED=true
CADDY_ADMIN_URL=http://localhost:2019

# --- exec extensions --------------------------------------------------------

# Comma-separated extra commands to allow in `exec_command` (in container)
# AND `host_exec` (on host), beyond the built-in read-only allowlist.
# Use sparingly.
# EXEC_EXTRA_ALLOWED=node,npm

# --- host_read_file allowlist -----------------------------------------------
#
# Comma-separated absolute path PREFIXES the `host_read_file` tool can read.
# Leave unset to disable the tool entirely. Common diagnostic paths:
# READ_FILE_ALLOWED_PREFIXES=/etc/nginx,/var/log,/etc/systemd

# Maximum bytes a single host_read_file call returns. Default 1 MiB.
# READ_FILE_MAX_BYTES=1048576
