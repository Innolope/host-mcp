# ============================================================================
# Transport
# ============================================================================
#
# stdio (default) — MCP client launches host-mcp as a local subprocess
# http            — listen as an HTTP server (for Claude.ai connectors etc.)
TRANSPORT=stdio

# Only used when TRANSPORT=http
# MCP_AUTH_TOKEN=replace-me-with-a-long-random-secret
# HTTP_PORT=3030
# HTTP_HOST=127.0.0.1
# HTTP_PATH=/mcp

# ============================================================================
# Backend — how host-mcp reaches the host it inspects
# ============================================================================
#
# If SSH_HOST is set, host-mcp opens an SSH connection (good when host-mcp
# runs on a different machine from the target).
#
# If SSH_HOST is UNSET, host-mcp runs commands directly on its own machine
# via child_process — no SSH key on disk, no SSH daemon involvement.
# This is the recommended setup when deploying host-mcp ON the box it
# inspects (HTTP mode for Claude.ai connectors).

# SSH_HOST=example.com
# SSH_PORT=22
# SSH_USER=deploy
# SSH_KEY_PATH=/path/to/.ssh/id_ed25519
# SSH_KEY_PASSPHRASE=
# SSH_PASSWORD=

# ============================================================================
# Docker (optional)
# ============================================================================

DOCKER_ENABLED=true
DOCKER_BIN=docker
# DEFAULT_COMPOSE_DIR=/srv/app
# DEFAULT_COMPOSE_PROJECT=app
# DEFAULT_CONTAINERS=app,worker,mongo

# ============================================================================
# MongoDB activity probe (optional)
# ============================================================================

# MONGO_CONTAINER=mongo
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB=app
# MONGO_COLLECTIONS=users,events,jobs

# ============================================================================
# Nginx (optional)
# ============================================================================

NGINX_ENABLED=true
NGINX_BIN=nginx

# ============================================================================
# Caddy (optional)
# ============================================================================

CADDY_ENABLED=true
CADDY_ADMIN_URL=http://localhost:2019

# ============================================================================
# exec extensions
# ============================================================================

# EXEC_EXTRA_ALLOWED=mongosh,node

# ============================================================================
# host_read_file allowlist (deny-by-default)
# ============================================================================

# READ_FILE_ALLOWED_PREFIXES=/etc/nginx,/etc/caddy,/var/log,/etc/systemd
# READ_FILE_MAX_BYTES=1048576
